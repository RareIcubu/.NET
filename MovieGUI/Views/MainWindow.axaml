<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:api="clr-namespace:Lab2_api;assembly=Lab2_api"
        xmlns:local="clr-namespace:MovieGUI.Views"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
        x:Class="MovieGUI.Views.MainWindow"
        Title="Absolute Cinema - Wyszukiwarka OMDb"
        Background="#f9f9f9">

    <DockPanel Margin="20">
        <Border DockPanel.Dock="Top" Margin="0,0,0,20" Padding="15" Background="White" CornerRadius="10" BoxShadow="0 2 5 0 #20000000">
            <StackPanel Orientation="Horizontal" Spacing="15" HorizontalAlignment="Center">
                <TextBox Name="SearchTextBox" Width="400" Watermark="Wpisz tytuł filmu... (np. Batman)" FontSize="16" />
                <Button Name="SearchButton" Content="Szukaj i Zapisz w bazie SQLite" 
                        Click="SearchButton_Click" 
                        Background="SkyBlue" Foreground="Black" FontSize="16" FontWeight="Bold" CornerRadius="5"/>
            </StackPanel>
        </Border>
        
        <ListBox Name="MoviesListBox" Background="Transparent" BorderThickness="0">
            <ListBox.ItemTemplate>
                <DataTemplate x:DataType="api:Movie">
                    <Border Margin="0,0,0,15" Padding="15" Background="White" CornerRadius="8" BoxShadow="0 1 3 0 #10000000">
                        <Grid ColumnDefinitions="Auto, *">
                            
                            <Border Grid.Column="0" CornerRadius="5" ClipToBounds="True" Margin="0,0,15,0">
                                <Image Width="100" Height="150" Stretch="UniformToFill" 
                                       local:AsyncImageLoader.Source="{Binding poster}"/>
                            </Border>
                            
                            <StackPanel Grid.Column="1" Spacing="5">
                                <TextBlock Text="{Binding title}" FontWeight="Bold" FontSize="22" Foreground="#2c3e50"/>
                                <TextBlock Text="{Binding genre}" FontStyle="Italic" Foreground="#7f8c8d" FontSize="14"/>
                                
                                <TextBlock Text="FABUŁA:" FontWeight="Bold" FontSize="12" Margin="0,10,0,0" Foreground="#34495e"/>
                                <TextBlock Text="{Binding plot}" TextWrapping="Wrap" FontSize="14" Foreground="#34495e"/>
                                
                                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                    <TextBlock Text="Rok wydania: " FontWeight="Bold" FontSize="12"/>
                                    <TextBlock Text="{Binding year}" FontSize="12"/>
                                    <TextBlock Text=" | Data premiery: " FontWeight="Bold" FontSize="12" Margin="10,0,0,0"/>
                                    <TextBlock Text="{Binding release_date}" FontSize="12"/>
                                </StackPanel>
                                
                                <TextBlock Text="OCENY:" FontWeight="Bold" FontSize="12" Margin="0,15,0,0" Foreground="#34495e"/>
                                <ItemsControl ItemsSource="{Binding ratings}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="api:Rating">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding source}" FontWeight="Bold" FontSize="11" Foreground="#95a5a6"/>
                                                <TextBlock Text=": " FontSize="11" Foreground="#95a5a6"/>
                                                <TextBlock Text="{Binding value}" FontSize="11" Foreground="#2ecc71"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </DockPanel>
</Window>